generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String      @id @default(cuid())
  name      String
  apiKey    String      @unique @default(cuid())
  contact   String?
  logo      String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  computers Computer[]
  devices   Device[]
}

model Device {
  id            String    @id @default(cuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name          String
  manufacturer  String?
  model         String?
  serialNumber  String?
  imei          String?
  os            String?
  osVersion     String?
  storageGB     Float?
  ramGB         Float?
  phoneNumber   String?
  ipAddress     String?
  macAddress    String?
  notes         String?

  purchaseDate  DateTime?
  warrantyExpiry DateTime?
  assetTag      String?
  status        String?    @default("active")
  healthStatus  String?    @default("ok")

  lastSeen      DateTime  @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([companyId, name])
}

model Computer {
  id            String    @id @default(cuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  hostname      String
  manufacturer  String?
  model         String?
  serialNumber  String?
  cpu           String?
  cpuCores      Int?
  ramGB         Float?
  diskGB        Float?
  disks         String?
  gpu           String?
  os            String?
  osVersion     String?
  osInstallDate DateTime?
  lastBootTime  DateTime?
  ipAddress     String?
  macAddress    String?
  biosVersion   String?
  notes         String?

  purchaseDate     DateTime?
  warrantyExpiry   DateTime?
  assetTag         String?
  status           String?    @default("active")
  healthStatus     String?    @default("ok")

  lastSeen      DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  history ComputerHistory[]

  @@unique([companyId, hostname])
}

model ComputerHistory {
  id          String   @id @default(cuid())
  computerId  String
  computer    Computer @relation(fields: [computerId], references: [id], onDelete: Cascade)
  field       String
  oldValue    String?
  newValue    String?
  changedBy   String?
  createdAt   DateTime @default(now())
}
